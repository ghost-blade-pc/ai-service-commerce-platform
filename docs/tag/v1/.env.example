# Copy this file to .env on the server and fill real values before running docker compose.

# MySQL / RabbitMQ / Redis Admin
MYSQL_USERNAME=root
MYSQL_ROOT_PASSWORD=123456
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin
REDIS_ADMIN_PASSWORD=admin

# Optional: group-buy-market logstash destination
LOGSTASH_HOST=127.0.0.1

# Weixin official account
WEIXIN_CONFIG_ORIGINALID=
WEIXIN_CONFIG_TOKEN=
WEIXIN_CONFIG_APP_ID=
WEIXIN_CONFIG_APP_SECRET=
WEIXIN_CONFIG_TEMPLATE_ID=

# Alipay sandbox / open platform
ALIPAY_APP_ID=
ALIPAY_MERCHANT_PRIVATE_KEY=
ALIPAY_ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
